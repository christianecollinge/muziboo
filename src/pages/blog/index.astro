---
import Layout from '../../layouts/Layout.astro';
import MuzibooHeader from '../../components/MuzibooHeader.astro';
import MuzibooFooter from '../../components/MuzibooFooter.astro';
import { getCollection } from 'astro:content';
import { content, defaultLang, type Lang } from '../../i18n';

const t = content[defaultLang as Lang];
const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Helper to get image from data or fallback to body
function getPostImage(post: any) {
  if (post.data.image) return post.data.image;
  
  // Fallback: try to extract first image from body
  const body = post.body || '';
  const match = body.match(/!\[.*?\]\((https?:\/\/[^)]+)\)/);
  return match ? match[1] : null;
}

// Helper to get clean ID/Slug for URL
function getPostSlug(post: any) {
  // In Astro 5, id is the filename relative to the collection
  return post.id.replace(/\.[^/.]+$/, ""); // Strip extension just in case
}
---

<Layout
  title="Muziboo Blog — Craft Over Metrics"
  description="Insights, guides, and stories for hobby musicians and bedroom producers who care about craft, not metrics."
  lang={defaultLang}
>
  <MuzibooHeader lang={defaultLang} content={t} />

  <main id="main-content" class="min-h-screen bg-muziboo-bg text-muziboo-text">
    <div class="max-w-7xl mx-auto py-16 px-4">
      <div class="mb-12">
        <p class="text-muziboo-text-muted uppercase tracking-widest text-xs mb-4">From the workshop</p>
        <h1 class="text-4xl font-semibold text-muziboo-text leading-tight">
          Real Music.<br />Real Conversation.
        </h1>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {posts.map(post => {
          const image = getPostImage(post);
          const slug = getPostSlug(post);
          
          return (
            <article class="flex flex-col group bg-muziboo-bg border border-muziboo-border rounded-xl overflow-hidden hover:border-muziboo-gold transition-all duration-300">
              <a href={`/blog/${slug}`} class="flex flex-col h-full">
                <div class="aspect-video w-full overflow-hidden bg-muziboo-border">
                  {image ? (
                    <img 
                      src={image} 
                      alt={post.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-muziboo-text-muted">
                      <span class="text-[10px] uppercase tracking-widest">In the workshop...</span>
                    </div>
                  )}
                </div>
                
                <div class="p-5 flex flex-col flex-1">
                  <div class="flex flex-wrap gap-2 mb-3">
                    {post.data.tags?.slice(0, 2).map(tag => (
                      <span class="text-muziboo-gold uppercase tracking-widest text-[10px] font-bold">{tag}</span>
                    ))}
                  </div>
                  
                  <h2 class="text-lg font-bold text-muziboo-text group-hover:text-muziboo-gold transition-colors mb-2 leading-tight line-clamp-2">
                    {post.data.title}
                  </h2>
                  
                  <p class="text-muziboo-text-muted text-xs leading-relaxed line-clamp-3 mb-4 flex-1">
                    {post.data.description}
                  </p>
                  
                  <div class="pt-4 border-t border-muziboo-border flex items-center justify-between mt-auto">
                    <span class="text-[10px] text-muziboo-text-muted uppercase tracking-widest">
                      {post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric'})}
                    </span>
                    <span class="text-muziboo-gold group-hover:translate-x-1 transition-transform">→</span>
                  </div>
                </div>
              </a>
            </article>
          );
        })}
      </div>

      {posts.length === 0 && (
        <div class="text-center py-20">
          <p class="text-muziboo-text-muted text-sm italic">The workshop is quiet today. New insights coming soon.</p>
        </div>
      )}
    </div>
  </main>

  <MuzibooFooter content={t} lang={defaultLang} />
</Layout>
